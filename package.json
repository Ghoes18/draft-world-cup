{
  "name": "7a0-engine",
  "version": "0.1.0",
  "description": "7a0 (Sete a Zero) — server-authoritative match engine + event timeline generator (MVP M1)",
  "type": "module",
  "license": "UNLICENSED",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts"
  },
  "scripts": {
    "sim": "tsx src/cli/simulate.ts",
    "import:squads": "tsx src/cli/import-squads.ts",
    "import:external": "tsx src/cli/import-external.ts",
    "import:photos": "tsx src/cli/import-photos.ts",
    "fetch:squads": "tsx src/cli/fetch-squads.ts",
    "build:catalog": "tsx src/cli/build-catalog.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
