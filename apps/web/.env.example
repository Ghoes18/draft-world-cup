# Auth + Convex (Better Auth) — required for mode C launch
#
# Copy to apps/web/.env.local and fill in values.
# Set secrets on Convex: `cd apps/web && npx convex env set …`

# From `npx convex dev`
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_CONVEX_SITE_URL=

# App URL (must match Convex SITE_URL)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set on Convex deployment (not in Next.js):
# BETTER_AUTH_SECRET=   — npx convex env set BETTER_AUTH_SECRET=$(openssl rand -base64 32)
# SITE_URL=http://localhost:3000
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# RESEND_API_KEY=       — optional; without it magic links log to Convex dashboard (dev)
# AUTH_EMAIL_FROM=      — e.g. "NINETY <auth@yourdomain.com>"
